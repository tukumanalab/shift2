# Server Configuration
PORT=8080

# Database Configuration
DATABASE_PATH=./data/shift.db

# Google Apps Script URL (for migration)
# Google Apps Scriptのウェブアプリケーションデプロイ後のURL
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Google OAuth Configuration (Frontend)
# Google Cloud ConsoleのOAuth 2.0 クライアントID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# 認可されたメールアドレス（カンマ区切り）
AUTHORIZED_EMAILS=user1@example.com,user2@example.com,admin@example.com

# Google Calendar Configuration
# GoogleカレンダーのカレンダーID
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# サービスアカウントのメールアドレス
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# サービスアカウントの秘密鍵（JSON形式からコピー）
# 注意: 改行は\nとして記述し、全体をダブルクォートで囲む
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Timezone
TIMEZONE=Asia/Tokyo
