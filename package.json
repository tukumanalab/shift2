{
  "name": "shift-app",
  "version": "1.0.0",
  "description": "アルバイトシフト管理アプリケーション",
  "main": "index.html",
  "scripts": {
    "dev": "npx http-server -p 8080",
    "dev:server": "nodemon --watch server/src --exec ts-node server/src/index.ts",
    "build": "tsc",
    "build:static": "echo 'No build needed for static files'",
    "start": "node dist/index.js",
    "preview": "npx http-server -p 8080",
    "deploy:gas": "cd gas && ./deploy.sh",
    "migrate:users": "ts-node server/scripts/migrate-users.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.0.8",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.js"
    ],
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "app.js",
      "!**/node_modules/**"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1"
  }
}
