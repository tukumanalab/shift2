{
  "name": "shift-app",
  "version": "1.0.0",
  "description": "アルバイトシフト管理アプリケーション",
  "main": "index.html",
  "scripts": {
    "dev": "nodemon --watch server/src --exec ts-node server/src/index.ts",
    "dev:static": "npx http-server -p 8080",
    "build": "node --max-old-space-size=4096 ./node_modules/.bin/tsc",
    "build:static": "echo 'No build needed for static files'",
    "start": "node dist/src/index.js",
    "preview": "npx http-server -p 8080",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:backend": "jest --testPathPattern=server/src/__tests__",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.8",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "googleapis": "^170.1.0",
    "ical-generator": "^10.0.0",
    "uuid": "^13.0.0"
  }
}
